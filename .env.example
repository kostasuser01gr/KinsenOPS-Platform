# Local-only template. Copy to .env.local and replace placeholders locally.

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/kinsen_ops"
DIRECT_URL="postgresql://user:password@localhost:5432/kinsen_ops"
USE_PG_ADAPTER=false

# Auth
AUTH_SECRET="replace-with-a-long-random-local-secret"
NEXTAUTH_URL="http://localhost:3000"

# Supabase browser/realtime
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="replace-with-your-anon-key"

# Supabase service role - server only, never expose in frontend-public prefixes
SUPABASE_SERVICE_ROLE_KEY="replace-with-your-service-role-key"
